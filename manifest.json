{
  "manifest_version": 2,
  "name": "AutoSolve Assistant",
  "version": "4.0",
  "description": "Automatically answers OneFD exams using AI.",
  "author": "Your Name",

  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon48.png"
  },

  "permissions": [
    "*://*.onefd.edu.dz/*",
    "https://openrouter.ai/*",
    "storage"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["*://*.onefd.edu.dz/*"],
      "js": [
        "content/constants.js",
        "content/utils.js",
        "content/ui.js",
        "content/solver.js",
        "content/main.js"
      ],
      "run_at": "document_end"
    }
  ],

  "browser_action": {
    "default_title": "AutoSolve Assistant",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  }
}